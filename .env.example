# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# REQUIRED — server will not start without this
JWT_SECRET=

# ── App URL ───────────────────────────────────────────────────────────────────
# The production domain of this app (used for CORS)
# Example: https://clinic.yourdomain.com
NEXT_PUBLIC_APP_URL=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Bot username without the @ symbol
TELEGRAM_BOT_USERNAME=
# The Telegram group chat ID where clinic staff receive booking notifications
TELEGRAM_GROUP_CHAT_ID=

# ── Cron Job Security ─────────────────────────────────────────────────────────
# Protects /api/cron/* endpoints from unauthorized calls
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Complaints Endpoint ───────────────────────────────────────────────────────
# Secret header value for GET /api/public/complaints (dev/admin use only)
# Generate with: openssl rand -hex 16
DEV_COMPLAINTS_SECRET=
