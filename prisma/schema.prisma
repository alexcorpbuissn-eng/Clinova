generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// CLINIC — SaaS Multi-Tenant Core
// ─────────────────────────────────────────────
model Clinic {
  id                  String     @id @default(uuid())
  name                String
  slug                String     @unique
  logoUrl             String?
  address             String?
  phone               String?
  telegramBotToken    String?
  telegramBotUsername String?
  telegramGroupChatId String?
  timezone            String     @default("Asia/Tashkent")
  isActive            Boolean    @default(true)
  plan                ClinicPlan @default(TRIAL)
  planExpiresAt       DateTime?

  doctors      Doctor[]
  appointments Appointment[]
  visits       Visit[]
  purchases    Purchase[]
  users        User[]
  procedures   Procedure[]
  leaves       Leave[]
  slots        Slot[]
  complaints   Complaint[]
  savedDrafts  SavedDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ClinicPlan {
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

// ─────────────────────────────────────────────
// DOCTORS
// ─────────────────────────────────────────────
model Doctor {
  id       String @id @default(uuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  firstName String
  lastName  String
  specialty String
  bio       String? @db.Text
  photoUrl  String?
  isActive  Boolean @default(true)

  workStartTime  String @default("09:00")
  workEndTime    String @default("18:00")
  breakStartTime String @default("13:00")
  breakEndTime   String @default("14:00")
  workingDays    Int[]  @default([1, 2, 3, 4, 5, 6])

  slots        Slot[]
  leaves       Leave[]
  appointments Appointment[]
  procedures   Procedure[]
  visits       Visit[]
  savedDrafts  SavedDraft[]

  telegramChatId   String?
  telegramUsername String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

// ─────────────────────────────────────────────
// LEAVES — Doctor time off / vacations
// ─────────────────────────────────────────────
model Leave {
  id       String @id @default(uuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  startTime DateTime
  endTime   DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([doctorId])
}

// ─────────────────────────────────────────────
// PROCEDURES — Doctor's services with durations
// ─────────────────────────────────────────────
model Procedure {
  id       String @id @default(uuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  doctorId        String
  doctor          Doctor        @relation(fields: [doctorId], references: [id])
  name            String
  durationMinutes Int
  price           Int           @default(0)
  isActive        Boolean       @default(true)
  appointments    Appointment[]
  savedDrafts     SavedDraft[]

  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([doctorId])
}

// ─────────────────────────────────────────────
// SLOTS — Doctor availability windows
// ─────────────────────────────────────────────
model Slot {
  id       String @id @default(uuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  doctorId    String
  doctor      Doctor       @relation(fields: [doctorId], references: [id])
  startTime   DateTime
  duration    Int
  isAvailable Boolean      @default(true)
  appointment Appointment?

  createdAt DateTime @default(now())

  @@unique([doctorId, startTime])
  @@index([clinicId])
  @@index([startTime])
}

// ─────────────────────────────────────────────
// PATIENTS — Global (no clinicId!)
// Isolation via Appointment.clinicId
// ─────────────────────────────────────────────
model Patient {
  id                   String        @id @default(uuid())
  telegramPhone        String?       @unique
  telegramChatId       String?       @unique
  telegramUsername     String?
  firstName            String
  lastName             String
  phone                String
  source               PatientSource @default(ONLINE)
  isVerified           Boolean       @default(false)
  cancellationsToday   Int           @default(0)
  lastCancellationDate DateTime?

  appointments Appointment[]
  visits       Visit[]
  savedDrafts  SavedDraft[]
  complaints   Complaint[]

  createdAt DateTime @default(now())

  @@index([telegramPhone])
  @@index([phone])
}

// ─────────────────────────────────────────────
// COMPLAINTS — Patient feedback
// ─────────────────────────────────────────────
model Complaint {
  id       String @id @default(uuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  message   String   @db.Text
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([patientId])
}

// ─────────────────────────────────────────────
// OTP — Global (no clinicId!)
// ─────────────────────────────────────────────
model Otp {
  id            String   @id @default(uuid())
  telegramPhone String
  code          String
  expiresAt     DateTime
  used          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([telegramPhone, used])
}

// ─────────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────────
model Appointment {
  id       String @id @default(uuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  slotId      String    @unique
  slot        Slot      @relation(fields: [slotId], references: [id])
  doctorId    String
  doctor      Doctor    @relation(fields: [doctorId], references: [id])
  procedureId String
  procedure   Procedure @relation(fields: [procedureId], references: [id])
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id])

  // Legacy raw fields
  patientEmail String?
  patientFirst String?
  patientLast  String?
  patientPhone String?

  description  String?    @db.VarChar(500)
  status       ApptStatus @default(SCHEDULED)
  cancelToken  String?    @unique
  cancelledBy  String?
  cancelNote   String?    @db.VarChar(1000)
  callAttempts Int        @default(0)

  reminderSent24h Boolean @default(false)
  reminderSent2h  Boolean @default(false)

  visit Visit?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([patientId])
  @@index([status, reminderSent24h, reminderSent2h])
}

// ─────────────────────────────────────────────
// SAVED DRAFTS — Delayed appointments
// ─────────────────────────────────────────────
model SavedDraft {
  id       String @id @default(uuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id])
  doctorId    String
  doctor      Doctor    @relation(fields: [doctorId], references: [id])
  procedureId String
  procedure   Procedure @relation(fields: [procedureId], references: [id])

  customDuration Int?
  status         DraftStatus @default(PENDING)
  createdAt      DateTime    @default(now())

  @@index([clinicId])
  @@index([patientId])
}

enum DraftStatus {
  PENDING
  CONVERTED
  CANCELLED
}

enum ApptStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// USERS — Staff auth
// clinicId nullable: SUPER_ADMIN has no clinic
// ─────────────────────────────────────────────
model User {
  id       String  @id @default(uuid())
  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id])

  telegramPhone String   @unique
  password      String?
  role          Role
  doctorId      String?

  createdAt DateTime @default(now())

  @@index([clinicId])
}

enum Role {
  SUPER_ADMIN // Platform owner — sees all clinics
  ADMIN       // Admin of one clinic
  DOCTOR
  RECEPTION
  INVENTORY
}

// ─────────────────────────────────────────────
// VISITS — Reception log
// ─────────────────────────────────────────────
model Visit {
  id       String @id @default(uuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  doctorId      String
  doctor        Doctor       @relation(fields: [doctorId], references: [id])
  patientId     String?
  patient       Patient?     @relation(fields: [patientId], references: [id])
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  patientName   String
  serviceName   String
  price         Int
  paidAmount    Int          @default(0)
  paymentMethod String?
  status        VisitStatus  @default(COMPLETED)
  source        VisitSource  @default(WALKIN)
  startTime     DateTime     @default(now())
  endTime       DateTime?
  note          String?

  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([doctorId])
  @@index([patientId])
  @@index([startTime])
  @@index([status])
}

enum VisitStatus {
  IN_PROGRESS
  COMPLETED
}

enum VisitSource {
  BOOKED
  WALKIN
}

enum PatientSource {
  ONLINE
  WALKIN
}

// ─────────────────────────────────────────────
// PURCHASES — Clinic expenses / inventory
// ─────────────────────────────────────────────
model Purchase {
  id       String @id @default(uuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  itemName   String
  price      Int
  sellerName String
  recordedBy String?

  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([createdAt])
}
